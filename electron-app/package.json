{
  "name": "ssbt-gaming-app-electron",
  "productName": "ssbt-gaming-app-electron",
  "version": "5.3.0",
  "description": "OPAP Lottery Electron application",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "node build/set-version.js && electron-forge start",
    "publish": "electron-forge publish",
    "lint": "eslint . && prettier \"**/*.(js|html|json)\" --check",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.(js|html|json)\"",
    "unit": "vitest run --silent",
    "unit:ui": "vitest --ui --open",
    "unit:watch": "vitest",
    "unit:coverage": "vitest --coverage",
    "package-mac": "node build/set-version.js && electron-forge package --platform=darwin",
    "package-win": "node build/set-version.js && electron-forge package --platform=win32",
    "make-mac": "node build/set-version.js && electron-forge make --makers=@electron-forge/maker-zip --platform=darwin",
    "make-win": "node build/set-version.js && electron-forge make --makers=@electron-forge/maker-zip --platform=win32",
    "test:playwrightAll": "playwright test",
    "test:playwrightBETTIETrue": "playwright test playwright/e2e/bettie",
    "test:playwrightBETTIEFalse": "playwright test -c playwright.bettiefalse.config.js",
    "test:playwrightRDG": "playwright test playwright/e2e/rdg",
    "test:playwrightVisual": "playwright test -g \"@visual\"",
    "test:playwrightVisual:update": "playwright test -g \"@visual\" --update-snapshots",
    "test:playwrightFile": "playwright test",
    "test:playwrightFile:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron-forge/plugin-vite": "^7.8.0",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.56.1",
    "@vitest/coverage-v8": "^3.2.2",
    "electron": "35.1.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "fs-extra": "^11.3.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.56.1",
    "prettier": "^3.5.3",
    "vite": "^5.4.16",
    "vitest": "^3.2.2"
  },
  "keywords": [],
  "author": {
    "name": "OPAP S.A."
  },
  "license": "MIT",
  "dependencies": {
    "await-to-js": "^3.0.0",
    "axios": "^1.8.4",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "electron-squirrel-startup": "^1.0.1",
    "http-status": "^2.1.0",
    "lodash": "^4.17.21",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.1"
  },
  "imports": {
    "#/*": "./playwright/*"
  }
}
